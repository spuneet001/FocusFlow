{
  "appId": "com.focusflow.app",
  "appName": "FocusFlow",
  "webDir": "dist",
  "server": {
    "androidScheme": "https",
    "iosScheme": "https"
  },
  "plugins": {
    "SplashScreen": {
      "launchAutoHide": true,
      "androidScaleType": "CENTER_CROP",
      "showSpinner": false,
      "backgroundColor": "#0a0a14"
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#0a0a14"
    }
  }
}
